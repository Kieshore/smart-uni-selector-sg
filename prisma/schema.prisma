// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id     Int      @id @default(autoincrement())
  first_name  String
  full_name   String   @unique
  citizenship String?
  email       String   @unique
  created_at  DateTime @default(now())

  academic_profiles UserAcademicProfile[]
  preferences       UserPreference[]

  @@map("users")
}

model UserAcademicProfile {
  academic_profile_id Int      @id @default(autoincrement())
  user_id             Int
  qualification_type  String
  current_gpa         Decimal? @db.Decimal(3, 2)
  projected_gpa       Decimal? @db.Decimal(3, 2)
  rank_points         Decimal? @db.Decimal(5, 2)
  diploma_name        String?
  institution_name    String?
  graduation_year     Int?
  english_grade       String?
  math_grade          String?
  computing_grade     String?
  created_at          DateTime @default(now())

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("user_academic_profiles")
}

model UserPreference {
  preference_id               Int      @id @default(autoincrement())
  user_id                     Int
  preferred_fields            Json?
  preferred_universities      Json?
  prioritise_salary           Int?
  prioritise_interest_fit     Int?
  prioritise_flexibility      Int?
  prioritise_admission_chance Int?
  prioritise_prestige         Int?
  wants_broad_degree          Boolean?
  created_at                  DateTime @default(now())

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("user_preferences")
}

model University {
  university_id   Int      @id @default(autoincrement())
  university_name String   @unique
  short_name      String?  @unique
  country         String?
  website_url     String?
  created_at      DateTime @default(now())

  courses Course[]

  @@map("universities")
}

model Course {
  course_id        Int      @id @default(autoincrement())
  university_id    Int
  course_name      String
  school           String?
  duration_years   Decimal? @db.Decimal(4, 1)
  career_prospects String?
  created_at       DateTime @default(now())

  university University                @relation(fields: [university_id], references: [university_id], onDelete: Cascade)
  admissions CourseAdmissionsProfile[]
  outcomes   CourseOutcome[]

  @@unique([university_id, course_name])
  @@map("courses")
}

model CourseAdmissionsProfile {
  admission_profile_id    Int      @id @default(autoincrement())
  course_id               Int
  min_gpa                 Decimal? @db.Decimal(3, 2)
  tenth_percentile_grades String?
  tenth_percentile_rp     Decimal? @db.Decimal(5, 2)
  required_subjects       Json?
  notes                   String?
  intake_size             Int?
  demand_score            Decimal? @db.Decimal(5, 2)
  competitiveness_band    String?
  year_recorded           Int
  source_type             String?
  last_updated            DateTime @updatedAt

  course       Course                       @relation(fields: [course_id], references: [course_id], onDelete: Cascade)
  band_metrics CourseAdmissionsBandMetric[]

  @@unique([course_id, year_recorded])
  @@map("course_admissions_profiles")
}

model CourseAdmissionsBandMetric {
  band_metric_id       Int      @id @default(autoincrement())
  admission_profile_id Int
  university_code      String
  qualification_type   String
  metric_type          String
  scope_type           String?
  band_label           String
  band_min             Decimal? @db.Decimal(5, 2)
  band_max             Decimal? @db.Decimal(5, 2)
  percentage_value     Decimal? @db.Decimal(5, 2)
  display_order        Int?
  source_note          String?
  created_at           DateTime @default(now())

  admission_profile CourseAdmissionsProfile @relation(fields: [admission_profile_id], references: [admission_profile_id], onDelete: Cascade)

  @@index([admission_profile_id])
  @@index([university_code, qualification_type, metric_type])
  @@map("course_admissions_band_metrics")
}

model CourseOutcome {
  outcome_id              Int      @id @default(autoincrement())
  course_id               Int
  basic_monthly_median    Decimal? @db.Decimal(10, 2)
  employment_rate_overall Decimal? @db.Decimal(5, 2)
  employment_rate_ft_perm Decimal? @db.Decimal(5, 2)
  career_prospects_score  Decimal? @db.Decimal(5, 2)
  source_year             Int
  source_type             String?
  created_at              DateTime @default(now())

  course Course @relation(fields: [course_id], references: [course_id], onDelete: Cascade)

  @@unique([course_id, source_year])
  @@map("course_outcomes")
}
